<%= collection_select_input_row form,
      :creator, @creators, :id, :name_with_domain,
      include_blank: t("general.no_change"),
      selected: @new_creator&.id || @default_creator&.id,
      button: (if policy(:creator).new?
                 {
                   path: new_creator_path,
                   label: t("creators.general.new")
                 }
               end) %>
<div>
  <%= form.label :collection_ids, Collection.model_name.human(count: 100) %>
</div>
<%= form.collection_select :collection_ids, @collections,
      :public_id, :name_with_domain, {
        selected: @new_collection&.public_id
      }, {
        multiple: true,
        class: "form-select",
        data: {controller: "tag-input", action: "turbo:morph@window->tag-input#reconnect"}
      } %>

<%= select_input_row form, :license, license_select_options, include_blank: t("general.no_change") %>

<%= checkbox_input_row form, :sensitive %>
