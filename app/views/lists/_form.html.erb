<p><%= t(".intro") %></p>

<%= form_with model: list, class: "container-md tabular-form" do |form| %>
  <%= TextInputRow(form: form, attribute: :name, label: List.human_attribute_name(:name), help: t(".name.help")) %>

  <div>
    <%= form.submit class: "btn btn-primary" %>
    <% if list.persisted? && policy(list).destroy? %>
      <%= link_to lists_path(list), {
            method: :delete,
            class: "float-end btn btn-outline-danger",
            data: {confirm: translate("views.lists.form.confirm_destroy")}
          } do %>
        <%= Icon(icon: "trash", label: t("general.delete")) %>
        <%= t("general.delete") %>
      <% end %>
    <% end %>
  </div>
<% end %>
